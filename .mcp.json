{
  "mcpServers": {
    "mcp-graph": {
      "command": "npx",
      "args": [
        "-y",
        "@mcp-graph-workflow/mcp-graph"
      ]
    },
    "gitnexus": {
      "command": "npx",
      "args": [
        "-y",
        "gitnexus",
        "mcp"
      ]
    },
    "serena": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--project",
        "."
      ]
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ]
    }
  }
}
